# 服务监听地址。宝塔反代到本机时建议保持 127.0.0.1。
HOST=127.0.0.1

# 订阅生成器端口。
PORT=5176

# 优选 IP 源服务地址。两个服务同一台 VPS 时使用本机地址即可。
IP_SOURCE_BASE=http://127.0.0.1:5173

# 数据目录，默认是项目内 data。
DATA_DIR=./data

# 管理接口访问令牌。强烈建议设置，用于保护 /api/profile 和 /api/preview 等管理接口。
# 设置后，页面里的“管理 Token”需要填写同一串令牌。
ADMIN_TOKEN=

# 可选：订阅链接访问令牌。留空表示不校验。
# 设置后订阅链接需要追加 ?token=你的令牌，例如 /sub/default?target=clash&token=xxx
SUB_ACCESS_TOKEN=
